{
  "name": "papernow",
  "version": "0.1.0",
  "private": true,
  "description": "PaperNow - Preprint literature management & collaboration platform for global researchers",
  "type": "module",
  "scripts": {
    "dev": "uni -p h5",
    "dev:prod": "uni -p h5 --mode production",
    "build": "uni build -p h5",
    "build:prod": "uni build -p h5 --mode production",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "supabase gen types typescript --linked > src/types/database.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "deploy:pages": "wrangler pages deploy dist/build/h5 --project-name=papernow",
    "deploy:worker": "wrangler deploy",
    "deploy:all": "npm run build && npm run deploy:pages"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-components": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5000820260430001",
    "@supabase/supabase-js": "^2.49.4",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.14",
    "@dcloudio/uni-automator": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5000820260430001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000820260430001",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.0",
    "eslint-plugin-vue": "^10.0.0",
    "prettier": "^3.5.3",
    "supabase": "^2.22.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "5.2.8",
    "vitest": "^2.1.9",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.14.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
