# ============================================
# PaperNow 环境变量模板
# ============================================
# 复制此文件为 .env 并填入实际值
# ⚠️  .env 文件已被 .gitignore 忽略，不会被提交
# ============================================

# --------------------------------------------
# Supabase 配置
# --------------------------------------------
# 项目区域: ca-central-1 (加拿大)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Secret Key (后端使用，不暴露给前端)
SUPABASE_SECRET_KEY=your-secret-key

# Supabase Service Role Key (Cloudflare Worker 使用，绕过 RLS)
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase 数据库密码
SUPABASE_DB_PASSWORD=your-db-password

# Supabase 数据库连接字符串
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# --------------------------------------------
# Cloudflare 配置
# --------------------------------------------
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_GLOBAL_API_KEY=your-cloudflare-global-api-key
CLOUDFLARE_ORIGIN_CA_KEY=your-cloudflare-origin-ca-key
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_S3_API=https://your-account-id.r2.cloudflarestorage.com

# --------------------------------------------
# GitHub 配置
# --------------------------------------------
GITHUB_TOKEN=your-github-pat

# --------------------------------------------
# 应用配置 - 子域名架构 (模式 A: 功能优先)
# --------------------------------------------
VITE_APP_TITLE=PaperNow
VITE_APP_DOMAIN=sunnynow.net
VITE_APP_URL=https://papernow.sunnynow.net
VITE_API_URL=https://api.papernow.sunnynow.net
